# ============ 前端 (Vite) ============
# 后端 API 地址
VITE_API_URL=http://localhost:8000

# ============ 后端 (Python) ============
# DeepSeek API Key — 可选，不填则自动使用 Mock 降级
DEEPSEEK_API_KEY=your_key_here

# DeepSeek API 基础地址 — 可选，默认官方地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============ 火山方舟 Ark (Seedance 2.0) ============
# Seedance 2.0 视频生成 API Key — 在 https://console.volcengine.com/ark/region:ark+cn-beijing/apikey 获取
ARK_API_KEY=ark-your_key_here
